# Inception environment configuration
# This file contains non-secret variables used by Docker Compose.
# Passwords must be stored in Docker secrets, not here

# My 42 login
# Used for the domain name and volume paths.
LOGIN=tbolsako

# Local domain requires by the subject
DOMAIN_NAME=tbolsako.42.fr

# MariaDB database used by WordPress.
MYSQL_DATABASE=wordpress

# MariaDB user used by WordPress.
MYSQL_USER=wp_user

# WordPress website title.
WP_TITLE=Inception

# WordPress administrator.
# Important: username must not contain "admin" or "administrator"
WP_ADMIN_USER=tbolsako_root
WP_ADMIN_EMAIL=tbolsako_root@example.com

# Regular WordPress user
WP_USER=editor
WP_USER_EMAIL=editor@example.com
